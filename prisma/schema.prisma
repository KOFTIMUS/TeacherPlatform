generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Teacher {
  id          String   @id
  name        String
  subject     String
  bio         String
  rating      Float
  reviewCount Int
  hourlyRate  Int
  avatarUrl   String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}